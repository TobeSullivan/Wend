[gd_resource type="Resource" script_class="MapResource" format=3]

[ext_resource type="Script" path="res://resources/tutorial_beat.gd" id="1_beat"]
[ext_resource type="Script" path="res://resources/map_resource.gd" id="2_map"]

[sub_resource type="Resource" id="Beat_load"]
script = ExtResource("1_beat")
trigger = "on_mission_load"
text = "Three waypoints this time. Same job, more room to be greedy with the path. You've got this - only a couple of hints from here."

[sub_resource type="Resource" id="Beat_build"]
script = ExtResource("1_beat")
trigger = "on_build_phase_start"
text = "Just a couple of suggestions - the rest of the maze is yours. Make them walk."
anchor = "board"
ghost_cells = Array[Vector2i]([Vector2i(5, 7), Vector2i(12, 6), Vector2i(19, 7)])

[resource]
script = ExtResource("2_map")
seed = 3
entry_cell = Vector2i(0, 8)
exit_cell = Vector2i(24, 8)
checkpoint_cells = Array[Vector2i]([Vector2i(7, 3), Vector2i(16, 11), Vector2i(21, 4)])
supply_cap = 25
round_count = 8
mob_count = 8
bronze_threshold = 8000
silver_threshold = 15000
gold_threshold = 24000
mission_index = 3
mission_name = "Switchbacks"
mission_description = "A longer forced route. Three waypoints, minimal hand-holding."
tutorial_beats = [SubResource("Beat_load"), SubResource("Beat_build")]
