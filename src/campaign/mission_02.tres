[gd_resource type="Resource" script_class="MapResource" format=3]

[ext_resource type="Script" path="res://resources/tutorial_beat.gd" id="1_beat"]
[ext_resource type="Script" path="res://resources/map_resource.gd" id="2_map"]

[sub_resource type="Resource" id="Beat_load"]
script = ExtResource("1_beat")
trigger = "on_mission_load"
text = "The enemy now has to touch two waypoints before it leaves. You can't change where those are - but you decide the path between them. Make every leg as long as you can."

[sub_resource type="Resource" id="Beat_build"]
script = ExtResource("1_beat")
trigger = "on_build_phase_start"
text = "We'll outline the first stretch. Finish the rest yourself - squeeze in as much walking as the space allows."
anchor = "board"
ghost_cells = Array[Vector2i]([Vector2i(4, 4), Vector2i(4, 5), Vector2i(4, 6), Vector2i(4, 7), Vector2i(4, 8)])

[resource]
script = ExtResource("2_map")
seed = 2
entry_cell = Vector2i(0, 8)
exit_cell = Vector2i(24, 8)
checkpoint_cells = Array[Vector2i]([Vector2i(8, 4), Vector2i(16, 11)])
supply_cap = 20
round_count = 7
mob_count = 8
bronze_threshold = 5000
silver_threshold = 10000
gold_threshold = 16000
mission_index = 2
mission_name = "The Long Way"
mission_description = "Checkpoints force the route. Maze the legs between the waypoints."
tutorial_beats = [SubResource("Beat_load"), SubResource("Beat_build")]
