[gd_resource type="Resource" script_class="MapResource" format=3]

[ext_resource type="Script" path="res://resources/tutorial_beat.gd" id="1_beat"]
[ext_resource type="Script" path="res://resources/map_resource.gd" id="2_map"]

[sub_resource type="Resource" id="Beat_load"]
script = ExtResource("1_beat")
trigger = "on_mission_load"
text = "Forget everything you know about tower defense. These enemies don't die - they shatter and instantly re-form, then keep marching. You'll never stop them, and you're not supposed to. Your only job is to deal as much damage as you can before the rounds run out. The longer you force them to walk through your fire, the higher you score."
blocking = true

[sub_resource type="Resource" id="Beat_build"]
script = ExtResource("1_beat")
trigger = "on_build_phase_start"
text = "Place towers on the glowing tiles. Don't just line them up - bend the path. Every extra step the enemy takes is another second your towers get to shoot."
anchor = "board"
ghost_cells = Array[Vector2i]([Vector2i(12, 6), Vector2i(12, 7), Vector2i(12, 8), Vector2i(12, 9), Vector2i(12, 10), Vector2i(12, 11), Vector2i(12, 12), Vector2i(12, 13)])

[sub_resource type="Resource" id="Beat_first"]
script = ExtResource("1_beat")
trigger = "on_first_tower_placed"
text = "That's a tower. It fires at anything in range. Tap it any time to upgrade it."
anchor = "tower"

[sub_resource type="Resource" id="Beat_start"]
script = ExtResource("1_beat")
trigger = "on_round_start"
text = "Here they come. Watch what happens when one falls."

[sub_resource type="Resource" id="Beat_kill"]
script = ExtResource("1_beat")
trigger = "on_first_kill"
text = "See? It's already back and walking again. You're not killing them - you're farming damage off them. That number climbing in the corner is the only thing that matters."
anchor = "respawn"

[sub_resource type="Resource" id="Beat_rend"]
script = ExtResource("1_beat")
trigger = "on_round_end"
text = "That's your score. Bronze, Silver, Gold are targets to chase, but the real game is the leaderboard. For now - keep going."
anchor = "score"

[sub_resource type="Resource" id="Beat_win"]
script = ExtResource("1_beat")
trigger = "on_win"
text = "That's the whole game. Everything from here just adds wrinkles. Next: the enemy won't walk in a straight line for you anymore."

[resource]
script = ExtResource("2_map")
seed = 1
entry_cell = Vector2i(0, 8)
exit_cell = Vector2i(24, 8)
checkpoint_cells = Array[Vector2i]([])
supply_cap = 10
round_count = 5
mob_count = 6
bronze_threshold = 2000
silver_threshold = 4000
gold_threshold = 7000
mission_index = 1
mission_name = "First Contact"
mission_description = "The core twist: enemies don't die. Build a short maze and farm damage."
tutorial_beats = [SubResource("Beat_load"), SubResource("Beat_build"), SubResource("Beat_first"), SubResource("Beat_start"), SubResource("Beat_kill"), SubResource("Beat_rend"), SubResource("Beat_win")]
