[gd_resource type="Theme" load_steps=2 format=3]

; App-wide base theme — distributes the canonical type (Fredoka SemiBold, wght 600)
; plus the dark outline to every text control, so screens stop re-declaring outline
; per-Label. See design/VISUAL_SYSTEM.md "Typography". Outline color = #1a2012.

[ext_resource type="FontVariation" path="res://assets/fonts/fredoka_bold.tres" id="1"]

[resource]
default_font = ExtResource("1")
default_font_size = 18
Label/colors/font_color = Color(1, 1, 1, 1)
Label/colors/font_outline_color = Color(0.101961, 0.12549, 0.070588, 1)
Label/constants/outline_size = 3
Button/colors/font_color = Color(1, 1, 1, 1)
Button/colors/font_outline_color = Color(0.101961, 0.12549, 0.070588, 1)
Button/constants/outline_size = 3
CheckButton/colors/font_color = Color(1, 1, 1, 1)
CheckButton/colors/font_outline_color = Color(0.101961, 0.12549, 0.070588, 1)
CheckButton/constants/outline_size = 3
OptionButton/colors/font_color = Color(1, 1, 1, 1)
OptionButton/colors/font_outline_color = Color(0.101961, 0.12549, 0.070588, 1)
OptionButton/constants/outline_size = 3
