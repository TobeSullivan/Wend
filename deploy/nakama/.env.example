# Copy to .env (gitignored) on the server and fill in real secrets before `docker compose up`.
# Generate strong values, e.g.:  openssl rand -hex 24

# Postgres password (used by both services over the private compose network).
POSTGRES_PASSWORD=change_me_postgres

# Nakama client "server key" — the shared key the Godot client authenticates the API with.
# This is NOT a user password; it gates API access. Set the same value in the Godot client.
NAKAMA_SERVER_KEY=change_me_server_key

# Shared secret for the co-op team-score submit RPC (submit_team_score in index.js). Only the
# Godot match server knows it; it guards the authoritative team leaderboard write so clients
# (which ship the http key) cannot forge team scores. MUST match WEND_SERVER_SUBMIT_SECRET in
# the match server's environment (see deploy/wend-server.service / wend-server.env).
WEND_SERVER_SUBMIT_SECRET=change_me_submit_secret

# Developer console (https://<box>:7351) login. Firewall 7351 to your own IP.
NAKAMA_CONSOLE_USER=admin
NAKAMA_CONSOLE_PASSWORD=change_me_console

# --- Steam login (used by the custom steam_auth RPC in data/modules/index.js) ---
# A Steam *publisher* Web API key (NOT a personal/user key). Create one in Steamworks:
#   Users & Permissions -> Manage Groups -> <your group> -> Create Publisher Web API Key.
# Leave blank to disable Steam login server-side (clients fall back to device auth).
STEAM_PUBLISHER_KEY=
# The appid the client's auth ticket is issued for. Wend Playtest = 4884650 (override at launch).
STEAM_APP_ID=4884650
# Must match SteamManager.WEB_API_IDENTITY in the Godot client exactly.
STEAM_IDENTITY=wend-nakama
